# ARIA — environment variables
# Copy to .env and fill in. None are required for `docker compose up` to succeed
# in MOCK mode — defaults below produce a fully working local demo.

# -----------------------------------------------------------------------------
# Service ports (defaults — change only if conflicts)
# -----------------------------------------------------------------------------
GATEWAY_PORT=8000
ENV_SERVICE_PORT=8001
ORCHESTRATOR_PORT=8002
VOICE_PORT=8003
MEMORY_PORT=8004
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Operational modes (all default to mock so demo works offline)
# -----------------------------------------------------------------------------
# MOCK_VOICE=1 → voice service returns canned transcripts and silent WAVs.
#               Set to 0 + ARIA_DOWNLOAD_MODELS=1 to use real Whisper/Piper.
MOCK_VOICE=1
MOCK_LLM=1
ARIA_DOWNLOAD_MODELS=0

# -----------------------------------------------------------------------------
# LLM (only used when MOCK_LLM=0)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# TTS backend selection (only when MOCK_VOICE=0)
#   TTS_BACKEND in {piper, elevenlabs}   — default: piper
# -----------------------------------------------------------------------------
TTS_BACKEND=piper
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# -----------------------------------------------------------------------------
# Env-service
# -----------------------------------------------------------------------------
ARIA_ENV_NAME=aria-personal-manager-v1
ARIA_ENV_MAX_STEPS=50
ARIA_ENV_DEFAULT_DIFFICULTY=medium
ARIA_ENV_SEED=

# -----------------------------------------------------------------------------
# Memory (Qdrant is provided as a sidecar container)
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
MEMORY_SQLITE_PATH=/data/aria.db

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
NEXT_PUBLIC_GATEWAY_WS_URL=ws://localhost:8000/ws
